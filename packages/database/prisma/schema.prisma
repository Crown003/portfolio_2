datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  id              String    @id @default(cuid())
  title           String
  excerpt         String
  content         String
  category        String
  publishedAt     DateTime  @default(now())
  readTime        String
  tags            String[]
  featured        Boolean   @default(false)
  thumbnailUrl    String?
  projectSummary  String?
  projectApproach String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comments        Comment[]
  likes           Like[]
  projects        Project[]
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  authorName String
  content    String
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  ipAddress String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Project {
  id             String   @id @default(cuid())
  title          String
  description    String
  content        String?
  imageUrl       String?
  liveUrl        String?
  githubUrl      String?
  tags           String[]
  showOnHomepage Boolean  @default(false)
  blogPostId     String?
  blogPost       Post?    @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())
}
